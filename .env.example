# ============================================
# Finanças Fácil - Variáveis de Ambiente
# ============================================

# ---- Banco de Dados ----
# Vercel KV - configurado automaticamente ao ativar a integração no painel Vercel
# KV_URL, KV_REST_API_URL, KV_REST_API_TOKEN, KV_REST_API_READ_ONLY_TOKEN

# ---- Autenticação ----
# Salt para hash de senhas (gere um valor aleatório seguro)
AUTH_SALT=seu-salt-seguro-aqui
# Secret para tokens de sessão (gere um valor aleatório seguro)
AUTH_SESSION_SECRET=seu-secret-seguro-aqui

# ---- Cakto ----
# Credenciais da API Cakto (obtidas em: https://app.cakto.com.br/dashboard/cakto-api)
CAKTO_CLIENT_ID=seu-client-id
CAKTO_CLIENT_SECRET=seu-client-secret
# Secret do webhook Cakto (campo "secret" enviado pela Cakto no payload do webhook)
CAKTO_WEBHOOK_SECRET=seu-webhook-secret
# URL do checkout (fornecida pela Cakto no painel de produtos)
NEXT_PUBLIC_CAKTO_CHECKOUT_URL=https://pay.cakto.com.br/SEU_CHECKOUT_ID

# ---- Suporte ----
NEXT_PUBLIC_SUPPORT_EMAIL=suporte@financasfacil.com.br
NEXT_PUBLIC_SUPPORT_WHATSAPP=5511999999999

# ---- Como Configurar Webhook na Cakto ----
# 1. Acesse: https://app.cakto.com.br/dashboard/apps
# 2. Clique "Criar App" > escolha "Webhook"
# 3. URL: https://SEU_DOMINIO/api/webhooks/cakto
# 4. Selecione os eventos: purchase_approved, refund, chargeback, purchase_refused
# 5. Salve o SECRET gerado e coloque em CAKTO_WEBHOOK_SECRET acima
