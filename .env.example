# ============================================
# Finanças Fácil - Variáveis de Ambiente
# ============================================

# ---- Autenticação ----
# Salt para hash de senhas (gere um valor aleatório)
AUTH_SALT=seu-salt-seguro-aqui
# Secret para tokens de sessão (gere um valor aleatório)
AUTH_SESSION_SECRET=seu-secret-seguro-aqui

# ---- Cakto ----
# URL do checkout (fornecida pela Cakto)
NEXT_PUBLIC_CAKTO_CHECKOUT_URL=https://checkout.cakto.com/SEU_LINK
# Secret para validar webhooks da Cakto
CAKTO_WEBHOOK_SECRET=seu-webhook-secret-aqui

# ---- Vercel KV ----
# O Vercel KV é configurado automaticamente ao adicionar a integração
# KV_URL, KV_REST_API_URL, KV_REST_API_TOKEN, KV_REST_API_READ_ONLY_TOKEN
# são injetados automaticamente pelo Vercel

# ---- Suporte ----
NEXT_PUBLIC_SUPPORT_EMAIL=suporte@financasfacil.com.br
NEXT_PUBLIC_SUPPORT_WHATSAPP=5511999999999
